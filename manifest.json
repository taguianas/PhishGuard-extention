{
  "manifest_version": 3,
  "name": "PhishGuard",
  "version": "2.0.0",
  "description": "Real-time phishing link detection for Gmail & Outlook. Heuristics, threat intelligence, Safe Browsing API, and domain age checks.",
  "author": "Anas TAGUI",

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "PhishGuard - Phishing Detector"
  },

  "options_page": "settings.html",

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/*",
        "https://outlook.live.com/*",
        "https://outlook.office.com/*",
        "https://outlook.office365.com/*",
        "https://outlook.com/*",
        "https://mail.yahoo.com/*",
        "https://mail.proton.me/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],

  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "contextMenus",
    "activeTab"
  ],

  "host_permissions": [
    "https://mail.google.com/*",
    "https://outlook.live.com/*",
    "https://outlook.office.com/*",
    "https://outlook.office365.com/*",
    "https://outlook.com/*",
    "https://mail.yahoo.com/*",
    "https://mail.proton.me/*",
    "https://openphish.com/*",
    "https://urlhaus-api.abuse.ch/*",
    "https://safebrowsing.googleapis.com/*",
    "https://rdap.org/*",
    "https://checkurl.phishtank.com/*",
    "https://www.virustotal.com/*"
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
